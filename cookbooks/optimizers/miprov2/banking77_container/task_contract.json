{
  "task_id": "banking77",
  "version": "0.1",
  "benchmark": "banking77",
  "objective": "Agent must classify each banking customer query into exactly one Banking77 intent label and maximize exact-match accuracy on held-out evaluation examples.",
  "submission_contract": {
    "task_kind": "container_rollout",
    "entrypoint": "container.py",
    "rollout_endpoint": "/rollout",
    "policy_fields": [
      "model",
      "provider",
      "inference_url"
    ],
    "expected_output": {
      "primary_metric": "accuracy",
      "required_detail_fields": [
        "predicted_intent",
        "expected_intent",
        "correct"
      ]
    }
  },
  "dataset_policy": {
    "source": "huggingface",
    "dataset_name": "banking77",
    "visible_splits": [
      "train",
      "test"
    ],
    "default_split": "train"
  },
  "verifier_contract": {
    "rubric_path": "VERIFIER_RUBRIC.md",
    "structured_rubric_path": "RUBRIC.json",
    "score_range": [
      0.0,
      1.0
    ]
  },
  "scoring_intent": {
    "primary_signal": "exact_match_accuracy",
    "hard_gates": [
      "single_label_selected",
      "label_in_taxonomy",
      "rollout_response_valid"
    ]
  }
}
