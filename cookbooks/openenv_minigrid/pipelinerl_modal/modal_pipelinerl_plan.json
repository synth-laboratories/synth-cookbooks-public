{
  "cookbook": "openenv_minigrid",
  "trainer": "pipelinerl_modal",
  "environment": "minigrid_container",
  "default_mode": "dry_run",
  "modal": {
    "app": "nanolong-qwen35-rl-cispo",
    "requires": ["modal token", "task app endpoint", "training dataset jsonl"]
  },
  "train_budget": {
    "baseline_rollouts": 16,
    "training_rollouts": 64,
    "heldout_rollouts": 32
  },
  "artifacts": [
    "local_smoke.json",
    "snapshot_proof.json",
    "baseline_summary.json",
    "modal_training_summary.json",
    "heldout_summary.json",
    "result_note.md"
  ]
}
